# SkillSnap AI - Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Groq API key from https://console.groq.com/keys
GROQ_API_KEY=your_api_key_here

# Optional: Override the Groq model (default: llama-3.1-8b-instant)
# Other options: llama-3.3-70b-versatile, gemma2-9b-it, mixtral-8x7b-32768
GROQ_MODEL=llama-3.1-8b-instant

# Database Configuration
# Default uses local MongoDB instance
MONGO_URI=mongodb://localhost:27017/skillsnap
